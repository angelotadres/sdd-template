#!/bin/sh
# Regenerate CHANGELOG.md from git history before every push.
# Install once with: git config core.hooksPath .githooks

python3 .claude/skills/changelog/scripts/changelog.py

# If CHANGELOG.md was updated, stage and commit it automatically.
if ! git diff --quiet CHANGELOG.md; then
  git add CHANGELOG.md
  git commit -m "Update changelog"
fi
